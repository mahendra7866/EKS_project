resource "aws_security_group" "eks_cluster" {

  name        = "eks-cluster-sg"
  description = "EKS Cluster Security Group"

  vpc_id = data.aws_vpc.eks_vpc.id

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}